{
  "name": "viabind-desktop",
  "version": "0.3.0",
  "description": "ViaBind powered by Electron + local Shiny backend",
  "main": "src/main/index.js",
  "engines": {
    "node": ">=20 <21 || >=22 <23 || >=24 <25"
  },
  "scripts": {
    "preinstall": "node scripts/check-node-version.mjs",
    "dev": "electron .",
    "smoke": "node scripts/smoke-desktop.mjs",
    "smoke:backend": "node scripts/smoke-backend.mjs",
    "ensure:r-runtime": "node scripts/ensure-r-runtime.mjs",
    "ensure:r-runtime:check": "node scripts/ensure-r-runtime.mjs --check-only",
    "pack:dir": "electron-builder --mac dir",
    "dist:mac": "npm run ensure:r-runtime && electron-builder --mac dmg zip",
    "dist:win": "npm run ensure:r-runtime && electron-builder --win nsis --x64",
    "dist": "npm run dist:mac"
  },
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.viabind.desktop",
    "productName": "ViaBind",
    "asar": true,
    "files": [
      "src/main/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../icons/ViaBind_1024.png",
        "to": "icon.png"
      },
      {
        "from": "../ITCSuiteWeb",
        "to": "itcsuite/ITCSuiteWeb",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../ITCprocessor",
        "to": "itcsuite/ITCprocessor",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../ITCsimfit",
        "to": "itcsuite/ITCsimfit",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../ITCgraph",
        "to": "itcsuite/ITCgraph",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/r-runtime",
        "to": "r-runtime",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.science",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "artifactName": "${productName}-${version}-windows-${arch}-setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "ViaBind"
    }
  }
}
