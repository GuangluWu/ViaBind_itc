linters: linters_with_defaults(line_length_linter = line_length_linter(120), object_name_linter = NULL, object_usage_linter = NULL, trailing_whitespace_linter = NULL, spaces_left_parentheses_linter = NULL, return_linter = NULL, indentation_linter = NULL, commented_code_linter = NULL)
exclusions: list("R/server/server_main.R")
